{
  "name": "tutorial",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap/cds": "^8",
    "express": "^4",
    "@cap-js/hana": "^1",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.6",
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8",
    "@sap/ux-specification": "UI5-1.145",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-tutelem": "cds watch --open tutelem/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-tutui5": "cds watch --open tutui5/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-tutadmin": "cds watch --open tutadmin/webapp/index.html?sap-ui-xx-viewCache=false",
    "undeploy": "cf undeploy tutorial --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "sapux": [
    "app/tutelem",
    "app/tutadmin"
  ],
  "cds": {
    "sql": {
      "native_hana_associations": false
    },
    "requires": {
      "[production]": {
        "db": "hana"
      },
      "auth": {
          "[development]": {
              "kind": "mocked",
                "users": {
                    "admin": {
                        "password": "admin",
                        "roles": [
                            "admin"
                        ]
                    },
                    "user": {
                        "password": "user",
                        "roles": [
                            "user"
                        ]
                    }
                }
          },
          "[production]": {
              "kind": "xsuaa"
          }
      },
      "html5-repo": true,
      "destinations": true,
      "workzone": true
    }
  }
}
